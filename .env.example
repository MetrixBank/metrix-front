# Copie para `.env` na raiz e preencha com os valores reais.

VITE_SUPABASE_URL=https://your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Chave para o header X-API-Key (ConexZap / Edge Function)
VITE_CONEXZAP_API_KEY=sua_chave_conexzap_aqui

# IDs de preço no Stripe (Products → Prices)
VITE_STRIPE_PRICE_MONTHLY=price_seu_id_mensal
VITE_STRIPE_PRICE_ANNUAL=price_seu_id_anual

VITE_ENABLE_MOCK_DATA=false

# true = lista de clientes na Gestão de Clientes usa dados mock (desenvolvimento / demo)
VITE_CUSTOMERS_MOCK=false

# true = ignora login e usa usuário fictício (apenas desenvolvimento; use false em produção)
VITE_BYPASS_AUTH=false
