# Configuration for ConexZap Webhook Function

# The API Key that ConexZap (or your testing tool) must send in the X-API-Key header
CONEXZAP_API_KEY=sua_chave_conexzap_aqui

# Supabase URL and Keys are automatically injected by the Supabase platform,
# but are listed here for reference if running locally with Supabase CLI
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key